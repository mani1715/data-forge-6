# DataForge Backend Configuration
# Copy this file to .env and add your actual values

# Flask Configuration
SECRET_KEY=your-secret-key-here
FLASK_ENV=production
FLASK_DEBUG=False

# Gemini AI API Key (REQUIRED for AI features)
# Get your FREE API key from: https://aistudio.google.com/apikey
GEMINI_API_KEY=your-gemini-api-key-here

# Instructions:
# 1. Go to https://aistudio.google.com/apikey
# 2. Sign in with your Google account
# 3. Click "Create API Key" (FREE - no credit card needed)
# 4. Copy the key and paste it above
# 5. Save this file as .env (remove .example)
# 6. Restart the backend: sudo supervisorctl restart backend

# NOTE: Without a valid API key, the app will still work but AI features will be disabled
# It will fall back to traditional data cleaning methods
